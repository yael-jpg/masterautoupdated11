NODE_ENV=production
PORT=5000
JWT_SECRET=replace-with-long-random-secret
DATABASE_URL=postgres://postgres:postgres@localhost:5432/masterauto
# Optional explicit fields (used when DATABASE_URL is not set):
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=masterauto

# SMTP (optional)
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_TLS_REJECT_UNAUTHORIZED=true
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM="MasterAuto <no-reply@your-domain.com>"
# SMTP_REPLY_TO=support@your-domain.com
