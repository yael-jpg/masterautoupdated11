NODE_ENV=production
PORT=5000
JWT_SECRET=replace-with-long-random-secret
# Optional alias used by some hosts: SECRET_KEY
SECRET_KEY=
DATABASE_URL=postgres://postgres:postgres@localhost:5432/masterauto?sslmode=require
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=10000
CORS_ORIGINS=https://your-site.netlify.app

# Optional explicit fields (used when DATABASE_URL is not set):
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=masterauto

# SMTP (optional)
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_TLS_REJECT_UNAUTHORIZED=true
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM="MasterAuto <no-reply@your-domain.com>"
# SMTP_REPLY_TO=support@your-domain.com
