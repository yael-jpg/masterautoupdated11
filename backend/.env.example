PORT=5000
NODE_ENV=development
JWT_SECRET=super-secret-key-change-me
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=masterauto
# Optional single URL format:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/masterauto

# Email Provider
# - Set to "resend" to use Resend API
# - Set to "smtp" to use nodemailer SMTP
# If left blank, the backend auto-detects (prefers Resend when configured).
EMAIL_PROVIDER=

# Resend (recommended)
RESEND_API_KEY=
RESEND_FROM="MasterAuto <no-reply@masterauto.local>"
RESEND_REPLY_TO=support@masterauto.local

# SMTP (for release notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="MasterAuto <no-reply@masterauto.local>"
SMTP_REPLY_TO=support@masterauto.local
