PORT=5000
NODE_ENV=development
JWT_SECRET=super-secret-key-change-me
# Optional alias used by some hosts: SECRET_KEY
SECRET_KEY=

# Database connection (choose one approach)
# A) Field-based connection
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=masterauto

# B) Single URL format (recommended for deployment)
# Example with explicit SSL mode for managed PostgreSQL:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/masterauto?sslmode=verify-full
DATABASE_URL=

# SSL behavior for pg client when DATABASE_URL is used.
# Set to false for providers that require SSL but use self-signed cert chains.
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=10000

# Comma-separated allowed browser origins for CORS/Socket.IO in production.
# Example: https://your-site.netlify.app,https://your-custom-domain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Email Provider
# - Set to "resend" to use Resend API
# - Set to "smtp" to use nodemailer SMTP
# If left blank, the backend defaults to SMTP.
# Note: Resend must be explicitly selected via EMAIL_PROVIDER=resend.
EMAIL_PROVIDER=

# Resend (recommended)
RESEND_API_KEY=
RESEND_FROM="MasterAuto <no-reply@masterauto.local>"
RESEND_REPLY_TO=support@masterauto.local

# SMTP (for release notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="MasterAuto <no-reply@masterauto.local>"
SMTP_REPLY_TO=support@masterauto.local

# Public app URLs (used in emails/links)
API_BASE_URL=http://localhost:5000
PORTAL_URL=http://localhost:5173/portal
